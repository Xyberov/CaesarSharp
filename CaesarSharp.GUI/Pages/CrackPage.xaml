<Page x:Class="CaesarSharp.GUI.Pages.CrackPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FF000000">

    <Page.Resources>
        <Style x:Key="FixedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#b8b8b8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#FF000000"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver"/>
                                    <VisualState x:Name="Focused"/>
                                    <VisualState x:Name="Disabled"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border Background="#FFC9C9C9" CornerRadius="4"/>
                            <ScrollViewer x:Name="ContentElement"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Auto"
                                          IsTabStop="False"
                                          AutomationProperties.AccessibilityView="Raw"/>
                            <TextBlock x:Name="PlaceholderTextContentPresenter"
                                       Text="{TemplateBinding PlaceholderText}"
                                       Foreground="#80000000"
                                       FontSize="{TemplateBinding FontSize}"
                                       Margin="{TemplateBinding Padding}"
                                       IsHitTestVisible="False"
                                       TextWrapping="{TemplateBinding TextWrapping}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="1440" Height="1024" Background="#FF000000">

            <Rectangle HorizontalAlignment="Center" VerticalAlignment="Top"
                       Width="1440" Height="97" Fill="#FF103D00"/>

            <Button Content="←" Margin="8,12,0,0"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Width="72" Height="72" FontSize="60"
                    Padding="0,-14,0,0"
                    Background="Transparent" BorderThickness="0"
                    Foreground="White"
                    Click="BackButton_Click"/>

            <TextBlock Text="Взлом&#160;смещения" FontSize="48"
                       Margin="100,18,0,0"
                       FontFamily="ms-appx:///Assets/Fonts/montserrat-subrayada-latin-700-normal.ttf#Montserrat Subrayada"
                       HorizontalAlignment="Left" VerticalAlignment="Top"
                       Height="64" FontWeight="Bold" Foreground="White"/>

            <Canvas Margin="0,96,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
                    Width="1440" Height="928" Background="Transparent">

                <Line Canvas.Top="439" X1="0" X2="1160" Y1="0" Y2="0"
                      StrokeThickness="9" Stroke="White"/>
                <Ellipse Width="43" Height="43" Fill="White"
                         Canvas.Left="1130" Canvas.Top="418"/>

                <Line Canvas.Left="550" Canvas.Top="260" X1="0" X2="500" Y1="0" Y2="0"
                      StrokeThickness="9" Stroke="White"/>
                <Ellipse Width="43" Height="43" Fill="White"
                         Canvas.Left="1020" Canvas.Top="238"/>

                <Line Canvas.Left="530" Canvas.Top="682" X1="0" X2="500" Y1="0" Y2="0"
                      StrokeThickness="9" Stroke="White"/>
                <Ellipse Width="43" Height="43" Fill="White"
                         Canvas.Left="1020" Canvas.Top="660"/>

                <Line X1="0" X2="130" Y1="0" Y2="130"
                      StrokeThickness="9" Stroke="White"
                      Canvas.Left="352" Canvas.Top="440"/>
                <Line Canvas.Left="539" Canvas.Top="440" X1="0" X2="100" Y1="0" Y2="-100"
                      StrokeThickness="9" Stroke="White"/>

                <TextBox x:Name="InputBox"
                         PlaceholderText="Изначальный текст..."
                         Style="{StaticResource FixedTextBoxStyle}"
                         FontFamily="ms-appx:///Assets/Fonts/Bitter-Regular.ttf#Bitter"
                         Width="740" Height="255" CornerRadius="10"
                         Canvas.Left="184" Canvas.Top="134"/>

                <TextBox x:Name="OutputBox"
                         PlaceholderText="Результат..."
                         Style="{StaticResource FixedTextBoxStyle}"
                         FontFamily="ms-appx:///Assets/Fonts/Bitter-Regular.ttf#Bitter"
                         Width="740" Height="255" CornerRadius="10"
                         Canvas.Left="184" Canvas.Top="550"
                         IsReadOnly="True"/>

                <Button Content="Запуск ⇅" Width="254" Height="51"
                        Background="#FF29750D" Foreground="White" BorderThickness="0"
                        FontFamily="ms-appx:///Assets/Fonts/Bitter-Regular.ttf#Bitter"
                        FontSize="24" Canvas.Left="585" Canvas.Top="443" CornerRadius="10"
                        Click="RunButton_Click"/>

                <Button Content="Загрузить файл ⤒" Width="254" Height="51"
                        Background="#FF29750D" Foreground="White" BorderThickness="0"
                        FontFamily="ms-appx:///Assets/Fonts/Bitter-Regular.ttf#Bitter"
                        FontSize="24" Canvas.Left="1100" Canvas.Top="235" CornerRadius="10"
                        Click="LoadFileButton_Click"/>

                <Button Content="Сохранить файл ⤓" Width="254" Height="51"
                        Background="#FF29750D" Foreground="White" BorderThickness="0"
                        FontFamily="ms-appx:///Assets/Fonts/Bitter-Regular.ttf#Bitter"
                        FontSize="24" Canvas.Left="1100" Canvas.Top="657" CornerRadius="10"
                        Click="SaveFileButton_Click"/>

                <TextBlock Text="Язык:" FontSize="24" Foreground="White"
                           FontFamily="ms-appx:///Assets/Fonts/Bitter-Regular.ttf#Bitter"
                           Canvas.Left="269" Canvas.Top="452" Height="29" Width="67"/>

                <ComboBox x:Name="LanguageBox" SelectedIndex="0"
                          Width="158" Height="51" FontSize="24"
                          FontFamily="ms-appx:///Assets/Fonts/Bitter-Regular.ttf#Bitter"
                          Background="#FF29750D" BorderBrush="#FF29750D"
                          Foreground="White" CornerRadius="10"
                          Canvas.Left="365" Canvas.Top="443">
                    <ComboBoxItem Content="Русский" Tag="Russian"/>
                    <ComboBoxItem Content="English" Tag="English"/>
                    <ComboBoxItem Content="Deutsch" Tag="German"/>
                    <ComboBoxItem Content="Français" Tag="French"/>
                    <ComboBoxItem Content="Español" Tag="Spanish"/>
                </ComboBox>

                <Button Content="📑" ToolTipService.ToolTip="Копировать"
                        Width="52" Height="52" FontSize="24"
                        Background="Transparent" Foreground="#80000000" BorderThickness="0"
                        CornerRadius="0"
                        Canvas.Left="869" Canvas.Top="750"
                        Click="CopyOutputButton_Click">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#40000000"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="#80000000"/>
                    </Button.Resources>
                </Button>

                <Button Content="📋" ToolTipService.ToolTip="Вставить"
                        Width="52" Height="52" FontSize="24"
                        Background="Transparent" Foreground="#80000000" BorderThickness="0"
                        CornerRadius="0"
                        Canvas.Left="869" Canvas.Top="334"
                        Click="PasteInputButton_Click">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#40000000"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="#80000000"/>
                    </Button.Resources>
                </Button>

            </Canvas>
        </Grid>
    </Viewbox>

</Page>
