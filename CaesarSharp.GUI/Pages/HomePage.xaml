<Page
    x:Class="CaesarSharp.GUI.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- Кнопка меню сверху слева -->
        <Button Content="&#xE700;"
                FontFamily="Segoe MDL2 Assets"
                FontSize="16"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="16,16,0,0"
                Background="Transparent"
                BorderThickness="0"
                Click="MenuButton_Click"/>

        <!-- Основной контент -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая часть — название -->
            <StackPanel Grid.Column="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="Работа"
                           FontSize="32"
                           FontWeight="Bold"/>
                <TextBlock Text="с шифром"
                           FontSize="32"
                           FontWeight="Bold"/>
                <TextBlock Text="Цезаря"
                           FontSize="32"
                           FontWeight="Bold"/>
            </StackPanel>

            <!-- Правая часть — кнопки -->
            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <Button Content="Работа с текстом"
                        Width="200"
                        Click="NavTextPage_Click"/>
                <Button Content="Brute force"
                        Width="200"
                        Click="NavCrackPage_Click"/>
                <Button Content="Инструкция использования"
                        Width="200"
                        Click="NavInstructionPage_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
