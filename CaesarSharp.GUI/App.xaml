<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="CaesarSharp.GUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CaesarSharp.GUI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="ButtonBackgroundPointerOver"   Color="#FF3A9B12"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressed"       Color="#FF1A4A07"/>
            <SolidColorBrush x:Key="ButtonForegroundPointerOver"   Color="White"/>
            <SolidColorBrush x:Key="ButtonForegroundPressed"       Color="White"/>
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver"  Color="Transparent"/>
            <SolidColorBrush x:Key="ButtonBorderBrushPressed"      Color="Transparent"/>

            <SolidColorBrush x:Key="TextBoxBackground"             Color="#FFC9C9C9"/>
            <SolidColorBrush x:Key="TextBoxBackgroundPointerOver"  Color="#FFD4D4D4"/>
            <SolidColorBrush x:Key="TextBoxBackgroundFocused"      Color="#FFDDDDDD"/>
            <SolidColorBrush x:Key="TextBoxForeground"             Color="#CC000000"/>
            <SolidColorBrush x:Key="TextBoxBorderBrushPointerOver" Color="#FF29750D"/>
            <SolidColorBrush x:Key="TextBoxBorderBrushFocused"     Color="#FF29750D"/>

            <SolidColorBrush x:Key="ComboBoxBackground"            Color="#FF29750D"/>
            <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#FF3A9B12"/>
            <SolidColorBrush x:Key="ComboBoxBackgroundPressed"     Color="#FF1A4A07"/>
            <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="Transparent"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>
