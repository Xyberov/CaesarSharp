<Window
    x:Class="CaesarSharp.GUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="CaesarSharp">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <Button x:Name="MenuButton"
                    Content="&#xE700;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="16"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="MenuButton_Click"/>
        </Grid>

        <Grid Grid.Row="1">

            <Frame x:Name="ContentFrame"/>

            <Rectangle x:Name="Overlay"
                       Fill="Black"
                       Opacity="0"
                       Visibility="Collapsed"
                       Tapped="Overlay_Tapped"/>

            <Grid x:Name="SideMenu"
                  Width="260"
                  HorizontalAlignment="Left"
                  Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                  Visibility="Collapsed">

                <StackPanel Margin="16,16,16,0">
                    <TextBlock Text="Меню"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,24"/>

                    <Button Content="Работа с текстом"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,8"
                            Click="NavTextPage_Click"/>

                    <Button Content="Brute force"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,8"
                            Click="NavCrackPage_Click"/>

                    <Button Content="Инструкция использования"
                            HorizontalAlignment="Stretch"
                            Click="NavInstructionPage_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
